    "schemas": {
      "Cluster": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "clusterType": {
            "type": "string",
            "enum": [
              "REPLICASET",
              "SHARDED",
              "GEOSHARDED"
            ]
